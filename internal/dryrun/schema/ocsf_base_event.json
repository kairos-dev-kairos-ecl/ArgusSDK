{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "argus-ocsf-base-event-v1.3",
  "title": "OCSF Base Event v1.3 (ArgusSDK subset)",
  "description": "Validates the fields ArgusSDK's OCSF mapper guarantees on every event class. This is not the full OCSF schema — it covers the base required + recommended fields that the ArgusSDK mapper always emits.",
  "type": "object",
  "required": ["class_uid", "category_uid", "activity_id", "type_uid", "time", "severity_id", "metadata"],
  "properties": {
    "class_uid": {
      "type": "integer",
      "minimum": 1000,
      "description": "OCSF class identifier. ArgusSDK emits 1004/1005/2004/4002/6001/6003/6005."
    },
    "category_uid": {
      "type": "integer",
      "minimum": 1,
      "description": "OCSF category. 1=System, 2=Findings, 4=Network, 6=Application."
    },
    "activity_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Activity within the class. 0=Unknown is allowed."
    },
    "type_uid": {
      "type": "integer",
      "minimum": 100000,
      "description": "Composite: class_uid * 100 + activity_id. Validated structurally in addition to this range check."
    },
    "time": {
      "type": "integer",
      "description": "Unix epoch milliseconds of the signal."
    },
    "severity_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6,
      "description": "1=Informational 2=Low 3=Medium 4=High 5=Critical 6=Fatal"
    },
    "metadata": {
      "type": "object",
      "required": ["version", "product"],
      "properties": {
        "version": {
          "type": "string",
          "const": "1.3.0",
          "description": "OCSF schema version. Must be exactly 1.3.0."
        },
        "product": {
          "type": "object",
          "required": ["vendor_name"],
          "properties": {
            "vendor_name": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        },
        "uid": {
          "type": "string"
        }
      }
    }
  }
}
